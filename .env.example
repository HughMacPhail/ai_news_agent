# ─── LiteLLM Proxy (preferred) ──────────────────────────────────
# Routes through local LiteLLM for cost tracking + tracing.
# Get this key from: cd dev-ops/observability && ./seed_budgets.sh
LITELLM_API_KEY=
LITELLM_BASE_URL=http://localhost:4000/v1

# ─── Langfuse Tracing (optional) ───────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3100

# ─── Anthropic (fallback — used if LITELLM_API_KEY is not set) ─
ANTHROPIC_API_KEY=

# ─── Telegram Delivery ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Data Sources ──────────────────────────────────────────────
EXA_API_KEY=

# Optional — Reddit (leave blank to skip)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ai_news_agent/1.0

# Optional — Twitter/X (leave blank to skip)
TWITTER_BEARER_TOKEN=

# ─── Schedule (24h format, default = 7:00 AM) ──────────────────
DAILY_HOUR=7
DAILY_MINUTE=0

# ─── News Settings ─────────────────────────────────────────────
MAX_ARTICLES_PER_SOURCE=10
LOOKBACK_HOURS=24
